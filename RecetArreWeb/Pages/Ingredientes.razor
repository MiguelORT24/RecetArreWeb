@page "/ingredientes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IIngredienteService ingredienteService
@inject IJSRuntime JSRuntime

<PageTitle>Gestión de Ingredientes</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 text-brand mb-1">Gestión de Ingredientes</h1>
                    <p class="text-muted mb-0">Administra los ingredientes disponibles</p>
                </div>
                <button class="btn btn-brand" @onclick="AbrirModalCrear">
                    <span class="bi bi-plus-circle"></span> Nuevo Ingrediente
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Éxito:</strong> @mensajeExito
            <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-4">
                            <input type="text" class="form-control" placeholder="Buscar ingrediente..."
                                   @bind="busqueda" @bind:event="oninput" />
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <button class="btn btn-outline-secondary w-100" @onclick="LimpiarBusqueda">
                                <span class="bi bi-x-circle"></span> Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        @if (ingredientes == null)
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <div class="spinner-border text-brand" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="text-muted mt-3">Cargando ingredientes...</p>
                </div>
            </div>
        }
        else if (!ingredientes.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <h5 class="alert-heading">No hay ingredientes</h5>
                    <p class="mb-0">Comienza creando tu primer ingrediente.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var ingrediente in IngredientesFiltrados)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-brand mb-0">@ingrediente.Nombre</h5>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-muted" type="button"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        <span class="bi bi-three-dots-vertical"></span>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <button class="dropdown-item" @onclick="() => AbrirModalEditar(ingrediente)">
                                                <span class="bi bi-pencil"></span> Editar
                                            </button>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <button class="dropdown-item text-danger" @onclick="() => EliminarIngrediente(ingrediente.Id)">
                                                <span class="bi bi-trash"></span> Eliminar
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <p class="card-text text-muted small">
                                <span class="bi bi-rulers me-1"></span>@ingrediente.UnidadMedida
                            </p>

                            <p class="card-text text-muted small flex-grow-1">
                                @(string.IsNullOrEmpty(ingrediente.Descripcion) ? "Sin descripción" : ingrediente.Descripcion)
                            </p>

                            <div class="border-top pt-2 mt-auto">
                                <small class="text-muted">
                                    <span class="bi bi-clock"></span>
                                    @ingrediente.CreadoUtc.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Vista de Lista</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">ID</th>
                                    <th scope="col">Nombre</th>
                                    <th scope="col">Unidad de Medida</th>
                                    <th scope="col">Descripción</th>
                                    <th scope="col">Fecha Creación</th>
                                    <th scope="col" class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ingredientes != null && ingredientes.Any())
                                {
                                    @foreach (var ingrediente in IngredientesFiltrados)
                                    {
                                        <tr>
                                            <td>@ingrediente.Id</td>
                                            <td class="fw-semibold">@ingrediente.Nombre</td>
                                            <td>@ingrediente.UnidadMedida</td>
                                            <td class="text-muted">@(string.IsNullOrEmpty(ingrediente.Descripcion) ? "-" : ingrediente.Descripcion)</td>
                                            <td>@ingrediente.CreadoUtc.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                        @onclick="() => AbrirModalEditar(ingrediente)">
                                                    <span class="bi bi-pencil"></span>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => EliminarIngrediente(ingrediente.Id)">
                                                    <span class="bi bi-trash"></span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            No hay ingredientes para mostrar
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(ingredienteEditando == null ? "Nuevo Ingrediente" : "Editar Ingrediente")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="nombreIngrediente"
                               placeholder="Ej: Tomate, Cebolla..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unidad de Medida <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="unidadMedidaIngrediente"
                               placeholder="Ej: gramos, ml, tazas..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" rows="3" @bind="descripcionIngrediente"
                                  placeholder="Descripción adicional sobre el ingrediente..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="btn btn-brand" @onclick="GuardarIngrediente" disabled="@guardando">
                        @(ingredienteEditando == null ? "Crear" : "Guardar cambios")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<IngredientesDto>? ingredientes;
    private string busqueda = "";
    private bool mostrarModal = false;
    private bool guardando = false;
    private IngredientesDto? ingredienteEditando = null;
    private string nombreIngrediente = "";
    private string unidadMedidaIngrediente = "";
    private string descripcionIngrediente = "";
    private string mensajeError = string.Empty;
    private string mensajeExito = string.Empty;

    private IEnumerable<IngredientesDto> IngredientesFiltrados
    {
        get
        {
            if (ingredientes == null) return Enumerable.Empty<IngredientesDto>();

            if (string.IsNullOrWhiteSpace(busqueda))
                return ingredientes;

            return ingredientes.Where(i =>
                i.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                (i.Descripcion?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                i.UnidadMedida.Contains(busqueda, StringComparison.OrdinalIgnoreCase)
            );
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarIngredientes();
    }

    private async Task CargarIngredientes()
    {
        try
        {
            ingredientes = await ingredienteService.ObtenerTodos();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar ingredientes: {ex.Message}";
            ingredientes = new List<IngredientesDto>();
        }
    }

    private void AbrirModalCrear()
    {
        ingredienteEditando = null;
        nombreIngrediente = "";
        unidadMedidaIngrediente = "";
        descripcionIngrediente = "";
        mensajeError = string.Empty;
        mostrarModal = true;
    }

    private void AbrirModalEditar(IngredientesDto ingrediente)
    {
        ingredienteEditando = ingrediente;
        nombreIngrediente = ingrediente.Nombre;
        unidadMedidaIngrediente = ingrediente.UnidadMedida;
        descripcionIngrediente = ingrediente.Descripcion ?? "";
        mensajeError = string.Empty;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        ingredienteEditando = null;
        nombreIngrediente = "";
        unidadMedidaIngrediente = "";
        descripcionIngrediente = "";
        mensajeError = string.Empty;
    }

    private async Task GuardarIngrediente()
    {
        if (string.IsNullOrWhiteSpace(nombreIngrediente))
        {
            mensajeError = "El nombre es requerido";
            return;
        }
        if (string.IsNullOrWhiteSpace(unidadMedidaIngrediente))
        {
            mensajeError = "La unidad de medida es requerida";
            return;
        }

        guardando = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            if (ingredienteEditando == null)
            {
                var nuevo = new IngredienteCreacionDto
                {
                    Nombre = nombreIngrediente,
                    UnidadMedida = unidadMedidaIngrediente,
                    Descripcion = string.IsNullOrWhiteSpace(descripcionIngrediente) ? null : descripcionIngrediente
                };

                var resultado = await ingredienteService.Crear(nuevo);

                if (resultado != null)
                {
                    mensajeExito = "Ingrediente creado exitosamente";
                    await CargarIngredientes();
                    CerrarModal();
                }
                else
                {
                    mensajeError = "No se pudo crear el ingrediente. Verifica que el nombre no esté duplicado.";
                }
            }
            else
            {
                var modificacion = new IngredienteModificacionDto
                {
                    Nombre = nombreIngrediente,
                    UnidadMedida = unidadMedidaIngrediente,
                    Descripcion = string.IsNullOrWhiteSpace(descripcionIngrediente) ? null : descripcionIngrediente
                };

                var resultado = await ingredienteService.Actualizar(ingredienteEditando.Id, modificacion);

                if (resultado)
                {
                    mensajeExito = "Ingrediente actualizado exitosamente";
                    await CargarIngredientes();
                    CerrarModal();
                }
                else
                {
                    mensajeError = "No se pudo actualizar el ingrediente";
                }
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarIngrediente(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro de eliminar este ingrediente?"))
            return;

        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            var resultado = await ingredienteService.Eliminar(id);

            if (resultado)
            {
                mensajeExito = "Ingrediente eliminado exitosamente";
                await CargarIngredientes();
            }
            else
            {
                mensajeError = "No se pudo eliminar el ingrediente";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al eliminar: {ex.Message}";
        }
    }

    private void LimpiarBusqueda()
    {
        busqueda = "";
    }
}
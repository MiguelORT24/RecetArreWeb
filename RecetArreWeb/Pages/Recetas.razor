@page "/recetas"
@using RecetArreWeb.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager Navigation

@code {
    [CascadingParameter] private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card p-3">
                <h3 class="mb-1">@Recipe.Title</h3>
                <p class="text-muted">Por @Recipe.Author &bull; @Recipe.Time min</p>

                <img src="@Recipe.ImageUrl" class="img-fluid rounded mb-3" alt="Imagen receta" />

                <h5>Ingredientes</h5>
                <ul>
                    @foreach (var ing in Recipe.Ingredients)
                    {
                        <li>@ing</li>


                    }
                </ul>

                <h5>Preparación</h5>
                <ol>
                    @foreach (var step in Recipe.Steps)
                    {
                        <li>@step</li>
                    }
                </ol>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <h4>Comentarios</h4>

    <div class="mt-3">
        <textarea class="form-control mb-2" @bind="NewCommentText" @bind:event="oninput" rows="3" placeholder="Escribe un comentario..." disabled="@(!IsLoggedIn)"></textarea>
        <div class="d-flex align-items-center">
            <button class="btn btn-success" @onclick="SubmitComment" disabled="@(!IsLoggedIn)">Enviar comentario</button>
            @if (!IsLoggedIn)
            {
                <small class="text-muted ms-3">Inicia sesión para publicar comentarios.</small>
            }
        </div>
        @if (mostrarErrorComentario)
        {
            <div class="text-danger small mt-2">@mensajeErrorComentario</div>
        }
    </div>

    <div class="mt-4">
        @if (Comments.Any())
        {
            @foreach (var c in Comments)
            {
                <div class="card mb-2">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between">
                            <strong>@(string.IsNullOrEmpty(c.CreadoPorUsuarioNombre) ? "Invitado" : c.CreadoPorUsuarioNombre)</strong>
                            <small class="text-muted">@c.CreadoUtc.ToString("g")</small>
                        </div>
                        <div>@c.Contenido</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-muted">Aún no hay comentarios.</div>
        }
    </div>
</div>

@code {
    private bool IsLoggedIn { get; set; } = false;
    private string? CurrentUserId { get; set; }
    private string? CurrentUserName { get; set; }

    private string NewCommentText { get; set; } = string.Empty;
    private bool mostrarErrorComentario = false;
    private string mensajeErrorComentario = string.Empty;

    private RecipeDto Recipe { get; set; } = new RecipeDto
    {
        Title = "Tacos de pollo a la mexicana",
        Author = "Chef Demo",
        Time = 35,
        ImageUrl = "https://via.placeholder.com/800x400.png?text=Receta+Demo",
        Ingredients = new List<string>
        {
            "500 g de pechuga de pollo",
            "1 cebolla",
            "2 tomates",
            "Chiles al gusto",
            "Tortillas",
            "Sal y pimienta"
        },
        Steps = new List<string>
        {
            "Cortar el pollo en tiras y sazonar.",
            "Sofreír cebolla y tomate.",
            "Agregar el pollo y cocinar hasta dorar.",
            "Calentar tortillas y servir con la preparación."
        }
    };

    private List<ComentarioDto> Comments { get; set; } = new List<ComentarioDto>
    {
        new ComentarioDto { CreadoPorUsuarioNombre = "Ana", Contenido = "Deliciosa receta, la probé hoy.", CreadoUtc = DateTime.Now.AddHours(-3) },
        new ComentarioDto { CreadoPorUsuarioNombre = "Luis", Contenido = "Muy fácil de preparar.", CreadoUtc = DateTime.Now.AddDays(-1) }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask;
        var user = authState.User;
        IsLoggedIn = user.Identity?.IsAuthenticated ?? false;
        if (IsLoggedIn)
        {
            CurrentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? user.FindFirst("sub")?.Value;
            CurrentUserName = user.Identity?.Name ?? user.FindFirst("name")?.Value ?? user.FindFirst("preferred_username")?.Value ?? user.FindFirst("email")?.Value;
        }
    }

    private void SubmitComment()
    {
        mostrarErrorComentario = false;
        mensajeErrorComentario = string.Empty;

        if (!IsLoggedIn)
        {
            mostrarErrorComentario = true;
            mensajeErrorComentario = "Debes iniciar sesión para publicar un comentario.";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewCommentText))
        {
            mostrarErrorComentario = true;
            mensajeErrorComentario = "El comentario no puede estar vacío.";
            return;
        }

        var nuevo = new ComentarioDto
        {
            Contenido = NewCommentText.Trim(),
            CreadoUtc = DateTime.Now,
            CreadoPorUsuarioId = CurrentUserId,
            CreadoPorUsuarioNombre = CurrentUserName,
            RecetaId = Recipe.Id
        };

        Comments.Insert(0, nuevo);
        NewCommentText = string.Empty;
    }

    private class RecipeDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Author { get; set; } = string.Empty;
        public int Time { get; set; }
        public string ImageUrl { get; set; } = string.Empty;
        public List<string> Ingredients { get; set; } = new();
        public List<string> Steps { get; set; } = new();
    }
}

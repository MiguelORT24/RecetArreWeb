@page "/recetas/crear"
@page "/recetas/editar/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IRecetaService recetaService
@inject IIngredienteService ingredienteService
@inject NavigationManager navigation

<PageTitle>@(Id == null ? "Nueva Receta" : "Editar Receta")</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <button class="btn btn-outline-secondary btn-sm mb-3" @onclick="VolverARecetas">
                <span class="bi bi-arrow-left me-1"></span> Volver a Recetas
            </button>
            <h1 class="h3 text-brand mb-1">@(Id == null ? "Nueva Receta" : "Editar Receta")</h1>
            <p class="text-muted mb-0">@(Id == null ? "Crea una nueva receta" : "Modifica los datos de tu receta")</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-brand" role="status"></div>
            <p class="text-muted mt-3">Cargando...</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Información General</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="modelo.Nombre"
                                   placeholder="Ej: Pasta a la boloñesa..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Instrucciones</label>
                            <textarea class="form-control" rows="8" @bind="modelo.Instrucciones"
                                      placeholder="Paso 1: ..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Ingredientes</h5>
                    </div>
                    <div class="card-body">
                        @if (ingredientes == null || !ingredientes.Any())
                        {
                            <p class="text-muted">No hay ingredientes disponibles. Crea ingredientes primero.</p>
                        }
                        else
                        {
                            <div class="row g-2">
                                @foreach (var ing in ingredientes)
                                {
                                    <div class="col-12 col-sm-6 col-md-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="ing-@ing.Id"
                                                   checked="@(modelo.IngredienteIds != null && modelo.IngredienteIds.Contains(ing.Id))"
                                                   @onchange="e => ToggleIngrediente(ing.Id, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label" for="ing-@ing.Id">
                                                @ing.Nombre
                                                <small class="text-muted">(@ing.UnidadMedida)</small>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-brand" @onclick="HandleSubmit" disabled="@guardando">
                                @if (guardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @(Id == null ? "Crear Receta" : "Guardar Cambios")
                            </button>
                            <button type="button" class="btn btn-outline-secondary"
                                    @onclick="VolverARecetas">
                                Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private RecetaCreacionDto modelo = new() { IngredienteIds = new List<int>() };
    private List<IngredientesDto>? ingredientes;
    private bool cargando = true;
    private bool guardando = false;
    private string mensajeError = string.Empty;

    private void VolverARecetas() => navigation.NavigateTo("/recetas");

    protected override async Task OnInitializedAsync()
    {
        ingredientes = await ingredienteService.ObtenerTodos();

        if (Id.HasValue)
        {
            var receta = await recetaService.ObtenerPorId(Id.Value);
            if (receta == null)
            {
                navigation.NavigateTo("/recetas");
                return;
            }

            modelo = new RecetaCreacionDto
            {
                Nombre = receta.Nombre,
                Instrucciones = receta.Instrucciones,
                IngredienteIds = receta.Ingredientes?.Select(i => i.Id).ToList() ?? new List<int>()
            };
        }

        cargando = false;
    }

    private void ToggleIngrediente(int id, bool seleccionado)
    {
        modelo.IngredienteIds ??= new List<int>();
        if (seleccionado && !modelo.IngredienteIds.Contains(id))
            modelo.IngredienteIds.Add(id);
        else if (!seleccionado)
            modelo.IngredienteIds.Remove(id);
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(modelo.Nombre))
        {
            mensajeError = "El nombre es requerido";
            return;
        }

        guardando = true;
        mensajeError = string.Empty;

        try
        {
            if (Id.HasValue)
            {
                var modificacion = new RecetaModificacionDto
                {
                    Nombre = modelo.Nombre,
                    Instrucciones = modelo.Instrucciones,
                    IngredienteIds = modelo.IngredienteIds
                };

                var resultado = await recetaService.Actualizar(Id.Value, modificacion);

                if (resultado)
                    navigation.NavigateTo($"/recetas/{Id.Value}");
                else
                    mensajeError = "No se pudo actualizar la receta";
            }
            else
            {
                var resultado = await recetaService.Crear(modelo);

                if (resultado != null)
                    navigation.NavigateTo($"/recetas/{resultado.Id}");
                else
                    mensajeError = "No se pudo crear la receta. Verifica los datos.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }
}